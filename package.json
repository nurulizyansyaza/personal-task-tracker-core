    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "prepublishOnly": "npm run build",
    "clean": "rm -rf dist"
  },
  "keywords": [
    "task-tracker",
    "shared",
    "types"
  ],
  "author": "nurulizyansyaza",
